---
import Layout from '../layouts/Layout.astro';
import { CDN } from '../lib/cdn';
---

<Layout title="About Us" description="Scaldarsi Motors — an international Manufacturing and Design firm. Montreal & Riyadh. The Philosophy of Perfection.">

  <!-- Hero -->
  <section style="min-height:70vh;display:flex;align-items:center;justify-content:center;position:relative;overflow:hidden;text-align:center;padding:120px 40px 80px;">
    <img src={CDN.frontDark} alt="" aria-hidden="true" width="1920" height="1080" loading="eager" fetchpriority="high" decoding="async" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;opacity:0.2;" />
    <div style="position:absolute;inset:0;background:rgba(0,0,0,0.6);"></div>
    <div style="position:relative;z-index:1;" class="fade-in">
      <p style="font-family:'Cinzel',serif;font-size:10px;letter-spacing:0.3em;text-transform:uppercase;color:#C9A96E;margin-bottom:16px;">Est. 2016</p>
      <h1 style="font-family:'Cormorant Garamond',serif;font-size:clamp(36px,5vw,72px);font-weight:400;color:#fff;margin-bottom:24px;line-height:1.1;">The Philosophy<br/>of Perfection</h1>
      <div class="gold-divider" style="margin:0 auto 28px;"></div>
      <p style="font-family:'DM Sans',sans-serif;font-size:15px;color:rgba(255,255,255,0.55);max-width:560px;margin:0 auto;line-height:1.8;">
        Scaldarsi Motors is an international Manufacturing and Design firm. We work on designing cars, private jets and yachts.
      </p>
    </div>
  </section>

  <!-- Heritage section -->
  <section style="max-width:1200px;margin:0 auto;padding:100px 40px;display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:center;" class="heritage-grid">

    <div>
      <p style="font-family:'Cinzel',serif;font-size:10px;letter-spacing:0.3em;text-transform:uppercase;color:#C9A96E;margin-bottom:20px;">Our Heritage</p>
      <h2 style="font-family:'Cormorant Garamond',serif;font-size:clamp(28px,3.5vw,48px);font-weight:400;color:#fff;line-height:1.2;margin-bottom:28px;">Scripting Art<br/>Into History</h2>
      <div class="gold-divider" style="margin:0 0 28px 0;"></div>
      <p style="font-family:'DM Sans',sans-serif;font-size:15px;color:rgba(255,255,255,0.6);line-height:1.9;margin-bottom:20px;">
        The Emperor Series embodies craftsmanship at its finest — a compilation of distinguished, international, master craftsmen. Every curve of the Emperor highlights Scaldarsi's unwavering commitment to product excellence, embodying integrity and evolution.
      </p>
      <p style="font-family:'DM Sans',sans-serif;font-size:15px;color:rgba(255,255,255,0.6);line-height:1.9;margin-bottom:20px;">
        Superseding the automotive industry, each Emperor is a masterpiece — the heirloom of the 21st century. The monument to artistry.
      </p>
      <p style="font-family:'Cormorant Garamond',serif;font-size:18px;font-style:italic;color:rgba(255,255,255,0.45);line-height:1.7;">
        "Take the journey with us, and watch as we script art into history."
      </p>
    </div>

    <div style="position:relative;">
      <img src={CDN.behind} alt="Emperor Collection" width="600" height="700" loading="lazy" decoding="async" style="width:100%;height:auto;object-fit:cover;border:1px solid rgba(201,169,110,0.2);" />
      <div style="position:absolute;bottom:-20px;right:-20px;width:80%;height:80%;border:1px solid rgba(201,169,110,0.15);z-index:-1;"></div>
    </div>

  </section>

  <!-- THE EMPEROR I — Specs & Story -->
  <section style="padding:120px 80px;background:#000;border-top:1px solid rgba(201,169,110,0.1);">
    <div style="max-width:1200px;margin:0 auto;">

      <div style="text-align:center;margin-bottom:80px;">
        <p style="font-family:'Cinzel',serif;font-size:10px;letter-spacing:0.35em;text-transform:uppercase;color:#C9A96E;margin-bottom:16px;">The Emperor I</p>
        <h2 style="font-family:'Cormorant Garamond',serif;font-size:clamp(28px,4vw,52px);font-weight:400;color:#fff;line-height:1.2;margin-bottom:20px;">Where Obsession<br/>Becomes Object</h2>
        <div class="gold-divider" style="margin:0 auto;"></div>
      </div>

      <!-- Four pillar stats -->
      <div class="stats-grid" style="display:grid;grid-template-columns:repeat(4,1fr);gap:2px;margin-bottom:80px;">
        {[
          { number: '888', unit: 'Horsepower', detail: 'Brabus-tuned V12' },
          { number: '24K', unit: 'Gold', detail: 'Body elements' },
          { number: '24', unit: 'Leathers', detail: 'Exotic animal hides' },
          { number: '110', unit: 'Units', detail: 'Produced worldwide' },
        ].map(stat => (
          <div style="border:1px solid rgba(201,169,110,0.12);padding:48px 32px;text-align:center;background:rgba(201,169,110,0.02);">
            <p style="font-family:'Cormorant Garamond',serif;font-size:clamp(40px,5vw,64px);font-weight:400;color:#fff;line-height:1;margin-bottom:8px;">{stat.number}</p>
            <p style="font-family:'Cinzel',serif;font-size:10px;letter-spacing:0.2em;text-transform:uppercase;color:#C9A96E;margin-bottom:8px;">{stat.unit}</p>
            <p style="font-family:'DM Sans',sans-serif;font-size:12px;color:rgba(255,255,255,0.3);">{stat.detail}</p>
          </div>
        ))}
      </div>

      <!-- Story paragraph -->
      <div style="max-width:800px;margin:0 auto;text-align:center;">
        <p style="font-family:'DM Sans',sans-serif;font-size:15px;color:rgba(255,255,255,0.55);line-height:1.9;margin-bottom:24px;">
          The Emperor I begins as a Mercedes-Maybach S600 — itself one of the world's most refined production vehicles. Scaldarsi's master craftsmen then spend months transforming it: a 6.2-litre twin-turbo V12 elevated by Brabus to 888 horsepower, 24-karat gold body elements applied by hand, and an interior assembled from twenty-four exotic animal leathers and seventy-eight types of wood veneer.
        </p>
        <p style="font-family:'DM Sans',sans-serif;font-size:15px;color:rgba(255,255,255,0.55);line-height:1.9;margin-bottom:24px;">
          Each of the 110 Emperors is unique. Not a variant. Not a trim level. A singular commission — designed in dialogue with its owner, built by hand, and delivered as an heirloom rather than an automobile.
        </p>
        <p style="font-family:'Cormorant Garamond',serif;font-size:20px;font-style:italic;color:rgba(255,255,255,0.4);line-height:1.7;">
          "Not an automobile. An heirloom."
        </p>
      </div>

    </div>
  </section>

  <!-- THE SCALDARSI WAY -->
  <section style="padding:120px 80px;background:#0a0a0a;border-top:1px solid rgba(201,169,110,0.08);">
    <div style="max-width:1200px;margin:0 auto;display:grid;grid-template-columns:1fr 2fr;gap:80px;align-items:start;" class="scaldarsi-way-grid">
      <div>
        <p style="font-family:'Cinzel',serif;font-size:10px;letter-spacing:0.35em;text-transform:uppercase;color:#C9A96E;margin-bottom:20px;">The Vision</p>
        <h2 style="font-family:'Cormorant Garamond',serif;font-size:clamp(28px,3.5vw,44px);font-weight:400;color:#fff;line-height:1.2;">The Scaldarsi<br/>Way</h2>
      </div>
      <div>
        <p style="font-family:'DM Sans',sans-serif;font-size:15px;color:rgba(255,255,255,0.55);line-height:1.9;margin-bottom:24px;">
          The Emperor was never meant to stand alone. Scaldarsi's founding vision — the Scaldarsi Way — held that true luxury is a complete world. An Emperor owner would never step from their car into an aircraft or onto a vessel that did not share its soul.
        </p>
        <p style="font-family:'DM Sans',sans-serif;font-size:15px;color:rgba(255,255,255,0.55);line-height:1.9;margin-bottom:40px;">
          The same 24-karat gold appointments, the same exotic leathers, the same obsessive craftsmanship — extended to Scaldarsi Yachts and Scaldarsi Private Jets. A total philosophy. A unified aesthetic. One way of moving through the world.
        </p>
        <div style="display:flex;gap:20px;flex-wrap:wrap;">
          <a href="/yachts" class="btn-gold" style="padding:12px 32px;font-size:10px;">Scaldarsi Yachts</a>
          <a href="/jets" class="btn-gold" style="padding:12px 32px;font-size:10px;">Private Jets</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Philosophy quote -->
  <section style="background:#1C1C1C;padding:100px 40px;text-align:center;">
    <div style="max-width:800px;margin:0 auto;">
      <p style="font-family:'Cinzel',serif;font-size:10px;letter-spacing:0.3em;text-transform:uppercase;color:#C9A96E;margin-bottom:32px;">Philosophy</p>
      <blockquote style="font-family:'Cormorant Garamond',serif;font-size:clamp(20px,3vw,38px);font-style:italic;color:#fff;line-height:1.5;margin-bottom:32px;">
        "Timeless. The wealth of the centuries and purveyor of civilizations."
      </blockquote>
      <p style="font-family:'DM Sans',sans-serif;font-size:15px;color:rgba(255,255,255,0.5);line-height:1.8;">
        Scaldarsi Motors is proud to announce their newest collection, the Emperor. 110 vehicles ranging from some of the world's leading brands. Take the journey with us, and watch as we script art into history.
      </p>
    </div>
  </section>

  <!-- Locations -->
  <section style="max-width:1200px;margin:0 auto;padding:100px 40px;">
    <p style="font-family:'Cinzel',serif;font-size:10px;letter-spacing:0.3em;text-transform:uppercase;color:#C9A96E;margin-bottom:48px;text-align:center;">Our Locations</p>
    <div class="locations-grid" style="display:grid;grid-template-columns:1fr 1fr;gap:2px;">

      <div style="padding:60px;border:1px solid rgba(201,169,110,0.15);background:rgba(201,169,110,0.02);">
        <h3 style="font-family:'Cormorant Garamond',serif;font-size:28px;font-weight:400;color:#fff;margin-bottom:8px;">Montreal</h3>
        <p style="font-family:'Cinzel',serif;font-size:10px;letter-spacing:0.2em;text-transform:uppercase;color:#C9A96E;margin-bottom:24px;">Quebec, Canada</p>
        <p style="font-family:'DM Sans',sans-serif;font-size:14px;color:rgba(255,255,255,0.5);margin-bottom:8px;">-1 (613) 371-3400</p>
        <a href="mailto:info@scaldarsimotors.com" style="font-family:'DM Sans',sans-serif;font-size:14px;color:#C9A96E;text-decoration:none;">info@scaldarsimotors.com</a>
      </div>

      <div style="padding:60px;border:1px solid rgba(201,169,110,0.15);background:rgba(201,169,110,0.02);">
        <h3 style="font-family:'Cormorant Garamond',serif;font-size:28px;font-weight:400;color:#fff;margin-bottom:8px;">Riyadh</h3>
        <p style="font-family:'Cinzel',serif;font-size:10px;letter-spacing:0.2em;text-transform:uppercase;color:#C9A96E;margin-bottom:24px;">Saudi Arabia</p>
        <p style="font-family:'DM Sans',sans-serif;font-size:14px;color:rgba(255,255,255,0.5);margin-bottom:8px;">+966 58 333 2873</p>
        <a href="mailto:info@scaldarsimotors.com" style="font-family:'DM Sans',sans-serif;font-size:14px;color:#C9A96E;text-decoration:none;">info@scaldarsimotors.com</a>
      </div>

    </div>
  </section>

  <!-- Contact Form -->
  <section id="contact" style="max-width:900px;margin:0 auto;padding:0 40px 120px;">
    <div style="text-align:center;margin-bottom:60px;">
      <p style="font-family:'Cinzel',serif;font-size:10px;letter-spacing:0.3em;text-transform:uppercase;color:#C9A96E;margin-bottom:16px;">Begin Your Inquiry</p>
      <h2 style="font-family:'Cormorant Garamond',serif;font-size:clamp(28px,3.5vw,48px);font-weight:400;color:#fff;">Enter the World of Scaldarsi</h2>
    </div>
    <form
      name="scaldarsi-inquiry"
      method="POST"
      data-netlify="true"
      netlify-honeypot="bot-field"
      style="display:grid;grid-template-columns:1fr 1fr;gap:20px;"
    >
      <input type="hidden" name="form-name" value="scaldarsi-inquiry" />
      <p style="display:none;"><input name="bot-field" /></p>

      <div>
        <label style="font-family:'Cinzel',serif;font-size:10px;letter-spacing:0.15em;text-transform:uppercase;color:rgba(255,255,255,0.5);display:block;margin-bottom:8px;">Name *</label>
        <input type="text" name="name" required placeholder="Your name" style="width:100%;background:rgba(255,255,255,0.04);border:1px solid rgba(201,169,110,0.25);color:#fff;padding:14px 18px;font-family:'DM Sans',sans-serif;font-size:14px;outline:none;box-sizing:border-box;" />
      </div>

      <div>
        <label style="font-family:'Cinzel',serif;font-size:10px;letter-spacing:0.15em;text-transform:uppercase;color:rgba(255,255,255,0.5);display:block;margin-bottom:8px;">Email *</label>
        <input type="email" name="email" required placeholder="your@email.com" style="width:100%;background:rgba(255,255,255,0.04);border:1px solid rgba(201,169,110,0.25);color:#fff;padding:14px 18px;font-family:'DM Sans',sans-serif;font-size:14px;outline:none;box-sizing:border-box;" />
      </div>

      <div>
        <label style="font-family:'Cinzel',serif;font-size:10px;letter-spacing:0.15em;text-transform:uppercase;color:rgba(255,255,255,0.5);display:block;margin-bottom:8px;">Phone</label>
        <input type="tel" name="phone" placeholder="+1 000 000 0000" style="width:100%;background:rgba(255,255,255,0.04);border:1px solid rgba(201,169,110,0.25);color:#fff;padding:14px 18px;font-family:'DM Sans',sans-serif;font-size:14px;outline:none;box-sizing:border-box;" />
      </div>

      <div>
        <label style="font-family:'Cinzel',serif;font-size:10px;letter-spacing:0.15em;text-transform:uppercase;color:rgba(255,255,255,0.5);display:block;margin-bottom:8px;">Interest</label>
        <select name="interest" style="width:100%;background:#0a0a0a;border:1px solid rgba(201,169,110,0.25);color:rgba(255,255,255,0.7);padding:14px 18px;font-family:'DM Sans',sans-serif;font-size:14px;outline:none;box-sizing:border-box;cursor:pointer;">
          <option>Emperor Collection</option>
          <option>Yachts</option>
          <option>Private Jets</option>
          <option>General Inquiry</option>
        </select>
      </div>

      <div style="grid-column:1 / -1;">
        <label style="font-family:'Cinzel',serif;font-size:10px;letter-spacing:0.15em;text-transform:uppercase;color:rgba(255,255,255,0.5);display:block;margin-bottom:8px;">Message *</label>
        <textarea name="message" required rows="5" placeholder="Tell us about your inquiry..." style="width:100%;background:rgba(255,255,255,0.04);border:1px solid rgba(201,169,110,0.25);color:#fff;padding:14px 18px;font-family:'DM Sans',sans-serif;font-size:14px;outline:none;box-sizing:border-box;resize:vertical;line-height:1.6;"></textarea>
      </div>

      <div style="grid-column:1 / -1;">
        <button type="submit" class="btn-gold">Submit Inquiry</button>
      </div>

    </form>
  </section>

</Layout>

<style>
  @media (max-width: 768px) {
    .heritage-grid { grid-template-columns: 1fr !important; gap: 40px !important; }
    .locations-grid { grid-template-columns: 1fr !important; }
    .stats-grid { grid-template-columns: 1fr 1fr !important; }
    .scaldarsi-way-grid { grid-template-columns: 1fr !important; gap: 40px !important; }
    section[style*="padding:120px 80px"] { padding: 80px 24px !important; }
  }
</style>
