---
import { CDN } from '../lib/cdn';
const currentPath = Astro.url.pathname;

const navLinks = [
  { label: 'Emperor Collection', href: '/emperor' },
  { label: 'Yachts', href: '/yachts' },
  { label: 'Private Jets', href: '/jets' },
  { label: 'About Us', href: '/about' },
];
---

<header id="navbar" style="position:fixed;top:0;left:0;right:0;z-index:100;transition:background 0.4s ease;">
  <nav style="max-width:1400px;margin:0 auto;padding:0 40px;height:96px;display:flex;align-items:center;justify-content:space-between;">

    <!-- Logo -->
    <a href="/" aria-label="Scaldarsi Motors Home" style="flex-shrink:0;">
      <img
        src={CDN.logo}
        alt="Scaldarsi Motors"
        width="72"
        height="72"
        loading="eager"
        decoding="async"
        style="width:72px;height:72px;object-fit:contain;border-radius:50%;"
      />
    </a>

    <!-- Desktop nav links -->
    <ul style="display:flex;gap:48px;list-style:none;align-items:center;" class="desktop-nav">
      {navLinks.map(link => (
        <li>
          <a
            href={link.href}
            class={`nav-link ${currentPath.startsWith(link.href) ? 'active' : ''}`}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Icons -->
    <div style="display:flex;gap:20px;align-items:center;">
      <a href="mailto:info@scaldarsimotors.com" aria-label="Email" style="color:rgba(255,255,255,0.6);transition:color 0.2s;" onmouseover="this.style.color='#C9A96E'" onmouseout="this.style.color='rgba(255,255,255,0.6)'">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
      </a>
      <!-- Mobile hamburger toggle -->
      <div id="mobile-menu-root" class="mobile-only"></div>
    </div>

  </nav>
</header>

<!-- Mobile nav overlay -->
<div id="mobile-nav-overlay" style="display:none;position:fixed;inset:0;background:#000;z-index:200;flex-direction:column;align-items:center;justify-content:center;gap:40px;">
  <button id="close-mobile-nav" aria-label="Close menu" style="position:absolute;top:24px;right:32px;background:none;border:none;color:#fff;cursor:pointer;">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
  </button>
  <img src={CDN.logo} alt="Scaldarsi Motors" width="80" height="80" loading="lazy" decoding="async" style="width:80px;height:80px;object-fit:contain;border-radius:50%;margin-bottom:20px;" />
  {navLinks.map(link => (
    <a href={link.href} class="nav-link" style="font-size:20px;letter-spacing:0.2em;">{link.label}</a>
  ))}
  <div style="display:flex;gap:24px;margin-top:20px;">
    <a href="https://www.facebook.com/scaldarsi" target="_blank" rel="noopener noreferrer" style="color:rgba(255,255,255,0.5);transition:color 0.2s;" onmouseover="this.style.color='#C9A96E'" onmouseout="this.style.color='rgba(255,255,255,0.5)'">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
    </a>
    <a href="https://www.instagram.com/scaldarsi_motors/" target="_blank" rel="noopener noreferrer" style="color:rgba(255,255,255,0.5);transition:color 0.2s;" onmouseover="this.style.color='#C9A96E'" onmouseout="this.style.color='rgba(255,255,255,0.5)'">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
    </a>
  </div>
</div>

<style>
  @media (max-width: 768px) {
    .desktop-nav { display: none !important; }
    .mobile-only { display: block !important; }
  }
  .mobile-only { display: none; }
</style>

<script>
  const navbar = document.getElementById('navbar');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 60) {
      navbar!.style.background = 'rgba(0,0,0,0.95)';
      navbar!.style.borderBottom = '1px solid rgba(201,169,110,0.15)';
    } else {
      navbar!.style.background = 'transparent';
      navbar!.style.borderBottom = 'none';
    }
  });

  const hamburgerBtn = document.createElement('button');
  hamburgerBtn.setAttribute('aria-label', 'Open menu');
  hamburgerBtn.style.cssText = 'background:none;border:none;color:#fff;cursor:pointer;padding:4px;';
  hamburgerBtn.innerHTML = `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>`;

  const mobileRoot = document.getElementById('mobile-menu-root');
  if (mobileRoot) mobileRoot.appendChild(hamburgerBtn);

  const overlay = document.getElementById('mobile-nav-overlay') as HTMLElement;
  const closeBtn = document.getElementById('close-mobile-nav');

  hamburgerBtn.addEventListener('click', () => { overlay.style.display = 'flex'; document.body.style.overflow = 'hidden'; });
  closeBtn?.addEventListener('click', () => { overlay.style.display = 'none'; document.body.style.overflow = ''; });
  overlay.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', () => { overlay.style.display = 'none'; document.body.style.overflow = ''; });
  });
</script>
