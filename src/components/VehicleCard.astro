---
interface Props {
  title: string;
  tagline: string;
  image: string;
  finish: string;
  specification: string;
  priceDisplay: string;
  slug: string;
  featured?: boolean;
}

const { title, tagline, image, finish, specification, priceDisplay, slug, featured } = Astro.props;
---

<article class="luxury-card" style="overflow:hidden;position:relative;">

  <!-- Image -->
  <div style="position:relative;overflow:hidden;aspect-ratio:16/10;">
    <img
      src={image}
      alt={title}
      width="800"
      height="500"
      loading="lazy"
      decoding="async"
      style="width:100%;height:100%;object-fit:cover;transition:transform 0.8s ease;display:block;"
      class="card-img"
    />
    <div style="position:absolute;inset:0;background:linear-gradient(to bottom, transparent 50%, rgba(0,0,0,0.8) 100%);"></div>
    {featured && (
      <span style="position:absolute;top:20px;right:20px;font-family:'Cinzel',serif;font-size:9px;letter-spacing:0.2em;text-transform:uppercase;color:#C9A96E;border:1px solid rgba(201,169,110,0.5);padding:6px 12px;">Featured</span>
    )}
  </div>

  <!-- Content -->
  <div style="padding:28px 32px 32px;">
    <div style="display:flex;gap:12px;margin-bottom:16px;">
      <span style="font-family:'DM Sans',sans-serif;font-size:10px;letter-spacing:0.1em;text-transform:uppercase;color:rgba(255,255,255,0.4);border:1px solid rgba(255,255,255,0.15);padding:4px 10px;">{finish}</span>
      <span style="font-family:'DM Sans',sans-serif;font-size:10px;letter-spacing:0.1em;text-transform:uppercase;color:rgba(255,255,255,0.4);border:1px solid rgba(255,255,255,0.15);padding:4px 10px;">{specification}</span>
    </div>
    <h3 style="font-family:'Cormorant Garamond',serif;font-size:22px;font-weight:600;color:#fff;margin-bottom:8px;line-height:1.2;">{title}</h3>
    <p style="font-family:'Cormorant Garamond',serif;font-size:16px;font-style:italic;color:rgba(255,255,255,0.5);margin-bottom:20px;">{tagline}</p>
    <div style="display:flex;align-items:center;justify-content:space-between;">
      <span style="font-family:'Cinzel',serif;font-size:11px;letter-spacing:0.1em;color:#C9A96E;">{priceDisplay}</span>
      <a href={`/emperor/${slug}`} class="btn-gold" style="padding:10px 24px;font-size:10px;">Inquire</a>
    </div>
  </div>

</article>

<style>
  article:hover .card-img { transform: scale(1.04); }
</style>
